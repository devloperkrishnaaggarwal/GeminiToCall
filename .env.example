# ─────────────────────────────────────────────
#  LiveKit Cloud
# ─────────────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
#  Google AI (Gemini Native Audio)
# ─────────────────────────────────────────────
GOOGLE_API_KEY=AIzaSy...

# ─────────────────────────────────────────────
#  Vobiz SIP Trunk Credentials
#  Get these from: https://docs.vobiz.ai/trunks
# ─────────────────────────────────────────────
VOBIZ_SIP_DOMAIN=your-trunk-id.sip.vobiz.ai
VOBIZ_USERNAME=your_vobiz_username
VOBIZ_PASSWORD=your_vobiz_password
VOBIZ_OUTBOUND_NUMBER=+1XXXXXXXXXX    # Your Vobiz DID number (E.164)

# ─────────────────────────────────────────────
#  LiveKit SIP Trunk IDs
#  Fill these in after running: python setup_trunk.py create-outbound
#                               python setup_trunk.py create-inbound
# ─────────────────────────────────────────────
OUTBOUND_TRUNK_ID=
INBOUND_TRUNK_ID=

# ─────────────────────────────────────────────
#  Optional
# ─────────────────────────────────────────────
# Default number to transfer calls to (if caller asks for human)
DEFAULT_TRANSFER_NUMBER=+1XXXXXXXXXX

# Agent name — must match dispatch rule in LiveKit dashboard
AGENT_NAME=voice-assistant
